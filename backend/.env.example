# Copy to .env and adjust. Paths are relative to backend/ unless absolute.
# Used by the API, tests, and run_local.py (run_local also loads this file).

# --- MongoDB (required for API; run_local sets dummy values) ---
MONGO_URL=mongodb://localhost:27017
MONGO_DB_NAME=matching_service
# TLS / Atlas on macOS: if you see "SSL: CERTIFICATE_VERIFY_FAILED / unable to get local issuer certificate",
# set this so PyMongo uses Mozilla's CA bundle (pip install certifi):
# MONGO_TLS_CA_FILE=certifi
# Last-resort LOCAL ONLY (never in prod): skips TLS verification entirely
# MONGO_TLS_INSECURE=1
# API reads job postings from this collection (enriched: onet_work_activities + skill_groups_origin_uuids on each doc)
MONGO_JOBS_COLLECTION=RankedJobsEnriched
# Client server selection timeout (ms); default 30000 if unset
# MONGO_SERVER_SELECTION_TIMEOUT_MS=30000
# Motor connection pool (passed to PyMongo). Tune for concurrent /match load.
# MONGO_MAX_POOL_SIZE=50
# MONGO_MIN_POOL_SIZE=0
# Filter: { is_active: true } — index { is_active: 1 } in Mongo for latency
# /match: optional active+location+remote prefilter (union of users), cap, then in-memory
# _job_matches_user_location. Set JOBS_RETRIEVAL_FILTER=0 to load all active (scripts, debugging).
# JOBS_RETRIEVAL_FILTER=1
# JOBS_RETRIEVAL_LIMIT=10000
# Inclusion projection on job find (smaller BSON over the wire). Set to 0 if a field is missing at runtime.
# JOBS_FIND_USE_PROJECTION=1
# In-memory location gate before scoring (matching_service._job_matches_user_location).
# MATCH_APPLY_LOCATION_FILTER=1

# Startup warmup (not per /match). Set to 0 to skip a step. WA lookup is off by default (enriched jobs).
# MONGO_WARMUP_ON_STARTUP=1
# WARMUP_OCCUPATIONS_CACHE=1
# WARMUP_WA_LOOKUP=0
# If 1, run warmup in a background task so the process binds immediately (first /match may be colder).
# WARMUP_NON_BLOCKING=0

# --- Local batch script (run_local.py only) ---
# Default: repo root data/supply.jsonl and data/demand.jsonl
# SUPPLY_JSONL_PATH=
# DEMAND_JSONL_PATH=

# --- Scoring mode ---
SCORING_MODE=multiplicative

# Additive mode weights (when SCORING_MODE=additive)
ADDITIVE_W1_SKILLS=0.40
ADDITIVE_W2_PREFERENCE=0.40
ADDITIVE_W3_MARKET=0.20

# --- Match list sizes ---
MATCH_TOP_K_OPPORTUNITIES=5
MATCH_TOP_K_OCCUPATIONS=5
MATCH_TOP_K_SKILL_GAPS=5

# --- Gate & success propensity (p_hat) ---
GATE_SIMILARITY_THRESHOLD=0.35
# Response filter for scored skill outputs:
# - essential_skill_matches similarity
# - skill_gap_recommendations proximity_score
# Defaults to GATE_SIMILARITY_THRESHOLD when unset.
# MATCH_RESPONSE_SKILL_MIN_SCORE=0.35
PHAT_ALPHA_ESSENTIAL=0.5
PHAT_BETA_READINESS=0.2
PHAT_GAMMA_MARKET=0.3

# --- Skill utility / feasibility (U) ---
SKILL_U_W_LOC=0.20
SKILL_U_W_ESS=0.50
SKILL_U_W_OPT=0.20
SKILL_U_W_GRP=0.10
SKILL_U_GAP_PENALTY=0.50
SKILL_U_TAU_ELIG=0.35
SKILL_MIN_ESSENTIAL_MATCH_SHARE=1.0
SKILL_ESSENTIAL_GEO_FLOOR=0.000001
# Score-weighted geometric mean for essential_fit. 0 = naive GM (current behaviour);
# >0 dampens influence of low row-max scores via weight = rowmax**alpha. Try 0.5 or 1.0.
SKILL_ESSENTIAL_DAMPING_ALPHA=0.0

# --- Per-rowmax rescaling target ---
# Whitened cosine for distinct skills sits in a narrow [0, ~0.3] working band; identity
# matches sit at 1.0 (tautological). To use the full [0, 1] discriminative range, every
# rowmax (per-essential best user-skill cosine) gets rescaled to min(1, rowmax / target)
# before the score-weighted GM. Identity rowmaxes clip to 1.0; non-identity stretch.
# Default lives in the whitened artefact's metadata (key: target_max_p999, computed
# at build time as p99.9 of 1M random-pair cosines). Set this env var to override.
# SKILL_RESCALE_TARGET=0.3

# --- Preferences (base + sigmoid + legacy scale) ---
PREFERENCE_BASE_CONSTANT=0.5
PREFERENCE_LEGACY_SCORE_SCALE=0.2
PREFERENCE_SIGMOID_NUMERATOR=4.0

# Per-attribute toggles (true/false, 1/0, yes/no)
PREF_ENABLE_EARNINGS=true
PREF_ENABLE_TASK_CONTENT=false
PREF_ENABLE_PHYSICAL_DEMAND=true
PREF_ENABLE_WORK_FLEXIBILITY=false
PREF_ENABLE_SOCIAL=true
PREF_ENABLE_CAREER_GROWTH=true
PREF_ENABLE_SOCIAL_MEANING=false

# --- Data files (defaults under backend/resources/; set absolute paths in production) ---
# OCCUPATION_JSON_PATH=resources/occupations/combined_occupation_database_with_wa.json
#
# Skill embedding artefact. Default: gemini-embedding-001 over preferredLabel
# + description (encodes semantic concept similarity), 3072-dim fp16.
# EMBEDDING_MODEL_PATH=resources/models/skill_embedding_model_gemini.pt
#
# Alternative: legacy Node2Vec graph-walk over the ESCO taxonomy (encodes
# ESCO-graph adjacency rather than semantic similarity), 64-dim fp32. Row
# order is shared with the Gemini artefact, so SKILL_TO_ROW_PATH is unchanged.
# EMBEDDING_MODEL_PATH=resources/models/skill_embedding_model.pt
#
# Threshold note: GATE_SIMILARITY_THRESHOLD, SKILL_U_TAU_ELIG, and
# SKILL_ESSENTIAL_DAMPING_ALPHA were originally tuned against the Node2Vec
# score distribution. Gemini produces sharper, more bimodal cosines (true
# matches near 1.0, true mismatches near 0.0), which makes the existing
# thresholds more conservative than they need to be. Recalibrate against
# the new distribution before claiming production-tuned settings.
# SKILL_TO_ROW_PATH=resources/models/skill_to_row.json
# SKILLS_CSV_PATH=resources/skill_taxonomy/skills.csv
# SKILL_GROUPS_CSV_PATH=resources/skill_taxonomy/skill_groups.csv
# SKILL_HIERARCHY_CSV_PATH=resources/skill_taxonomy/skill_hierarchy.csv

# --- Njila prep script (prep_njila_for_matching.py) ---
# Read Compass collections from Mongo instead of JSON exports:
# NJILA_PREP_SOURCE=mongo
# Optional: separate Mongo URI for Njila source data (overrides MONGO_URL for this script only):
# NJILA_PREP_SOURCE_DB_URI=mongodb://...
# Database name (defaults to compass-application-njila if unset):
# NJILA_MONGO_DB=compass-application-njila
# Optional collection name overrides if they differ in your cluster:
# NJILA_COLL_EXPLORE=explore_experiences_director_state
# NJILA_COLL_USER_PREFERENCES=user_preferences
# NJILA_COLL_JOB_PREFERENCES=job_preferences
# NJILA_COLL_PLAIN_PERSONAL=plain_personal_data
# NJILA_COLL_PROGRAMME_SKILLS=programme_skills
# JSON file mode: directory containing the five compass-application-njila.*.json files
# NJILA_JSON_INPUT_DIR=data/njila_supply_side
# Output JSONL path (default data/njila_match_input.jsonl under repo root)
# NJILA_OUTPUT_JSONL=data/njila_match_input.jsonl
